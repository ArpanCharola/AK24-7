APP_NAME=AK24/7Jobs
DEBUG=false
SECRET_KEY=change-me-in-production
# Comma-separated list of frontend origins allowed to call the API in CORS.
# Production example: https://app.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_apply

REDIS_URL=redis://localhost:6379/0
# Celery is retained only for legacy apply tasks; the lean scheduler is APScheduler.
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

OPENAI_API_KEY=sk-your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small

# Background scheduler (APScheduler). Off until discovery/matching land; then set true
# to run periodic discovery (every 6h) + the daily digest (07:30 IST).
ENABLE_SCHEDULER=false

# Google Sign-In + Gmail — new "AK24/7Jobs" Google Cloud project (read/label/send).
# Create a Web-application OAuth client, add the redirect URIs below, add yourself as a
# Test User on the OAuth consent screen. (gmail.modify + gmail.send are RESTRICTED scopes
# → CASA assessment required before public launch; Testing mode covers <=100 users.)
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/email/callback
FRONTEND_URL=http://localhost:5173
# Optional: dedicated Fernet key for encrypting stored tokens. If blank, a stable
# key is derived from SECRET_KEY. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Path to your local clone of skilluence/resume-formatter (for tailored PDF rendering).
RESUME_FORMATTER_PATH=

# ---- India job sources (free-first) ----
# Tier 2: Jooble direct API (POST https://jooble.org/api/{key}); get a key from jooble.org/api/about.
JOOBLE_API_KEY=
# Tier 3 scraping toggles (all-in but per-source switchable). JobSpy = naukri/indeed/
# linkedin/google/glassdoor. TimesJobs RSS is low-risk (official feed).
ENABLE_JOBSPY=false
ENABLE_SCRAPE_TIMESJOBS=true
# Comma-separated residential proxies for Tier-3 scraping (Naukri/Google/LinkedIn).
SCRAPE_PROXIES=

# ---- Deprecated for the India pivot (left for back-compat; safe to leave blank) ----
# SerpAPI + Apify were the USA paid-aggregator/enrichment tiers — not used by AK24/7Jobs.
SERPAPI_KEY=
APIFY_TOKEN=
APIFY_CONTACT_ACTOR_ID=vdrmota~contact-info-scraper

PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
