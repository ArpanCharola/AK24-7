APP_NAME=AK24/7Jobs
DEBUG=false
SECRET_KEY=change-me-in-production
# Comma-separated list of frontend origins allowed to call the API in CORS.
# Production example: https://app.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_apply

REDIS_URL=redis://localhost:6379/0
# Celery is retained only for legacy apply tasks; the lean scheduler is APScheduler.
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

OPENAI_API_KEY=sk-your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small

# Shared warehouse scheduler. Runs one aggregation at 00:37 and 12:37 IST.
# Set false only in non-scheduler replica processes.
ENABLE_SCHEDULER=true

# Google Sign-In + Gmail — new "AK24/7Jobs" Google Cloud project (read/label/send).
# Create a Web-application OAuth client, add the redirect URIs below, add yourself as a
# Test User on the OAuth consent screen. (gmail.modify + gmail.send are RESTRICTED scopes
# → CASA assessment required before public launch; Testing mode covers <=100 users.)
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/email/callback
FRONTEND_URL=http://localhost:5173
# Optional: dedicated Fernet key for encrypting stored tokens. If blank, a stable
# key is derived from SECRET_KEY. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Path to your local clone of skilluence/resume-formatter (for tailored PDF rendering).
RESUME_FORMATTER_PATH=

# ---- India job sources (free-first) ----
# Tier 2: Jooble direct API (POST https://jooble.org/api/{key}); get a key from jooble.org/api/about.
JOOBLE_API_KEY=
# TimesJobs RSS is low-risk (official feed).
ENABLE_SCRAPE_TIMESJOBS=true
#
# Tier 3 scraping (all-in, self-host, free). TIER3_ENABLED is the master gate;
# leave false in any hosted env. Per-source toggles let you disable a board that
# is breaking. Boards: jobspy (indeed/google/naukri/linkedin/glassdoor) + custom
# adapters (instahyre/cutshort/wellfound/hirect).
TIER3_ENABLED=true
SCRAPE_INDEED=true
SCRAPE_GOOGLE=true
SCRAPE_NAUKRI=false
SCRAPE_LINKEDIN=true
SCRAPE_GLASSDOOR=false
SCRAPE_INSTAHYRE=true
SCRAPE_CUTSHORT=true
SCRAPE_WELLFOUND=true
SCRAPE_HIRECT=false
SCRAPE_HIRIST=true
# Comma-separated proxies for Tier-3 (http://user:pass@host:port,...). Empty =
# direct. LinkedIn/Glassdoor/Wellfound are unreliable without residential proxies.
SCRAPE_PROXIES=
# Circuit breaker: trip a source after N consecutive failures, retry after COOLDOWN s.
SCRAPE_CIRCUIT_THRESHOLD=3
SCRAPE_CIRCUIT_COOLDOWN=1800
# Stealth browser for JS/anti-bot boards (Wellfound + Glassdoor/LinkedIn fallback).
STEALTH_ENABLED=true
# Hirect mobile API (reverse-engineered) — fill after the capture spike; blank = [].
HIRECT_TOKEN=
HIRECT_API_BASE=

# ---- Deprecated for the India pivot (left for back-compat; safe to leave blank) ----
# SerpAPI + Apify were the USA paid-aggregator/enrichment tiers — not used by AK24/7Jobs.
SERPAPI_KEY=
APIFY_TOKEN=
APIFY_CONTACT_ACTOR_ID=vdrmota~contact-info-scraper

PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
